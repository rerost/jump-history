{
    "name": "jump-history",
    "publisher": "rerost",
    "displayName": "Jump History",
    "version": "0.0.1",
    "main": "./out/extension.js",
    "engines": {
        "vscode": "^1.97.0"
    },
    "activationEvents": [
        "*"
    ],
    "contributes": {
        "taskDefinitions": [{
            "type": "jump-history",
            "required": ["task"],
            "properties": {
                "task": {
                    "type": "string",
                    "description": "The task name"
                }
            }
        }]
    },
    "scripts": {
        "test": "node ./out/test/runTest.js --timeout 60000",
        "compile": "tsc -p ./",
        "pretest": "npm run compile"
    },
    "devDependencies": {
        "@types/glob": "^7.1.3",
        "@types/mocha": "^8.2.3",
        "@types/node": "^14.18.63",
        "@types/vscode": "^1.97.0",
        "@vscode/test-electron": "^2.3.8",
        "glob": "^7.1.6",
        "mocha": "^8.3.2",
        "typescript": "^4.2.3"
    }
} 