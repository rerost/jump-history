{
  "name": "jump-history",
  "displayName": "jump-history",
  "description": "VSCode extension to track and manage code navigation history including definition jumps and file opens",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished", "onLanguage:*"],
  "main": "./extension.js",
  "contributes": {
    "commands": [{
      "command": "jump-history.helloWorld",
      "title": "Hello World"
    }]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.97.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "eslint": "^9.19.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}
