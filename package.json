{
  "name": "jump-history",
  "displayName": "jump-history",
  "description": "VSCode extension to track and manage code navigation history including definition jumps and file opens",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:*",
    "onCommand:jumpHistory.showQuickPick"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "jumpHistory",
          "name": "Jump History"
        }
      ]
    },
    "commands": [
      {
        "command": "jumpHistory.showQuickPick",
        "title": "Show Jump History",
        "category": "Jump History"
      }
    ],
    "keybindings": [
      {
        "command": "jumpHistory.showQuickPick",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./node_modules/@vscode/test-electron/out/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.19",
    "@types/vscode": "^1.97.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.19.0",
    "glob": "^11.0.1",
    "mocha": "^11.1.0",
    "typescript": "^5.7.3"
  }
}
