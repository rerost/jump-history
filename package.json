{
  "name": "jump-history",
  "displayName": "Jump History",
  "description": "Track and visualize code navigation history when jumping between definitions",
  "version": "1.1.0",
  "publisher": "rerost",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jumpHistory.showTree",
        "title": "Jump History: Show Navigation Tree"
      },
      {
        "command": "jumpHistory.reset",
        "title": "Jump History: Reset Navigation Tree"
      }
    ]
  },
  "dependencies": {
    "eslint": "^9.21.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^16.x",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "mocha": "^10.2.0",
    "vscode-test": "^1.6.1",
    "eslint": "^8.36.0",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc src/test/runTest.ts --outDir out/test --module commonjs --target ES2020",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "lint": "eslint src --ext ts || true",
    "test": "node ./out/test/runTest.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rerost/jump-history.git"
  },
  "keywords": [
    "vscode",
    "extension",
    "navigation",
    "code-reading"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rerost/jump-history/issues"
  },
  "homepage": "https://github.com/rerost/jump-history#readme"
}
